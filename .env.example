# Copy this to .env and fill in real values before deploying.
# NEVER commit the real .env file — it's already in .gitignore.

# ---- Database ----
DB_NAME=memory_engine
DB_USER=memory_engine
DB_PASSWORD=CHANGE_ME_use_a_long_random_password

# ---- Redis ----
# If your Redis requires auth (recommended in prod), set REDIS_PASSWORD and
# uncomment the `--requirepass` line for the redis service in docker-compose.prod.yml.
REDIS_PASSWORD=

# ---- JWT ----
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_minimum_32_characters_random_string

# ---- CORS ----
# Comma-separated list of your real frontend origin(s). No trailing slashes.
APP_CORS_ALLOWED_ORIGINS=https://app.yourdomain.com

# ---- Rate limiting ----
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ---- Gemini (optional — falls back to local embeddings if empty) ----
GEMINI_API_KEY=

# ---- Grafana ----
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ---- Domain (used by nginx/certbot) ----
DOMAIN_NAME=api.yourdomain.com
CERTBOT_EMAIL=you@yourdomain.com
